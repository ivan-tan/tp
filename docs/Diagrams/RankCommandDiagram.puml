@startuml
skinparam SequenceMessageAlignment center

actor User
participant ":ExpensiveLeh" as Main
participant ":Parser" as Parser
participant "r:RankCommand" as RankCommand
participant "managers:Managers" as Managers
participant ":ExpenseManager" as ExpenseManager
participant ":UI" as UI

User -> Main : inputs "rank expenses"
activate Main

Main -> Parser : readCommand("rank expenses")
activate Parser

create RankCommand
Parser -> RankCommand : new RankCommand("expense")
activate RankCommand
RankCommand --> Parser : r
deactivate RankCommand

Parser --> Main : r
deactivate Parser

Main -> RankCommand : execute(managers, ui)
activate RankCommand

RankCommand -> Managers : getExpenseManager()
activate Managers
Managers --> RankCommand : expenseManager
deactivate Managers

RankCommand -> ExpenseManager : getCategoryTotals()
activate ExpenseManager
ExpenseManager --> RankCommand : unsortedTotals
deactivate ExpenseManager

note right of RankCommand
  Converts unsortedTotals Map
  to a sorted ArrayList
end note

RankCommand -> UI : showRanking(rankedList, "expense")
activate UI

note right of UI
  Loops through list and
  generates visual bar
  blocks for each category
end note

caption Note: Sequence for "rank loans" follows the same path as "rank expenses" here.

UI --> User : displays ranked bar chart
UI --> RankCommand
deactivate UI

RankCommand --> Main
deactivate RankCommand

Main --> User
deactivate Main
@enduml