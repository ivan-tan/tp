@startuml SearchCommandSequenceDiagram
skinparam Style strictuml
skinparam SequenceMessageAlignment center

actor User
participant ":ExpensiveLeh" as Main
participant ":Parser" as Parser
participant "s:SearchCommand" as SearchCommand
participant ":ExpenseManager" as ExpenseManager
participant ":LoanManager" as LoanManager
participant ":UI" as UI

User -> Main : inputs "search KEYWORD"
activate Main

Main -> Parser : readCommand("search KEYWORD")
activate Parser

create SearchCommand
Parser -> SearchCommand : new SearchCommand(keyword)
activate SearchCommand
SearchCommand --> Parser : s
deactivate SearchCommand

Parser --> Main : s
deactivate Parser

Main -> SearchCommand : execute(managers, ui)
activate SearchCommand

note right of ExpenseManager
    Searches through all expenses
    to find matches by keyword
    (in description or category)
end note

SearchCommand -> ExpenseManager : searchByKeyword(keyword)
activate ExpenseManager
ExpenseManager --> SearchCommand : matchedExpenses
deactivate ExpenseManager

note right of ExpenseManager
    Maps matched expenses to
    their actual indices in the
    full expense list
end note

SearchCommand -> ExpenseManager : searchByKeywordWithIndices(keyword)
activate ExpenseManager
ExpenseManager --> SearchCommand : actualIndices
deactivate ExpenseManager

note right of LoanManager
    Searches through all loans
    to find matches by keyword
    (in description or category)
end note

SearchCommand -> LoanManager : searchByKeyword(keyword)
activate LoanManager
LoanManager --> SearchCommand : matchedLoans
deactivate LoanManager

alt no results found (both empty)
    SearchCommand -> UI : showMessage("No expenses or loans found...")
    activate UI
    UI --> SearchCommand
    deactivate UI
else results found
    note right of SearchCommand
        Formats results into:
        - Header with search keyword
        - Expenses section (if any)
        - Loans section (if any)
        Each row: Index, Category,
        Name, Value, Date
    end note

    SearchCommand -> UI : showMessage(formattedResults)
    activate UI
    UI --> SearchCommand
    deactivate UI
end

SearchCommand --> Main
deactivate SearchCommand

Main --> User : displays search results
deactivate Main

@enduml

